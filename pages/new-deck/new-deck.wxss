/* 新建卡组页面样式 - 与首页统一风格 */
page {
  --primary: #ff4757;
  --secondary: #ffa502;
  --accent: #2ed573;
  --neon-pink: #ff6b9d;
  --neon-blue: #00d2ff;
  --neon-purple: #a55eea;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 标题 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 10rpx 50rpx;
}

.header-center {
  flex: 1;
  text-align: center;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(90deg, var(--neon-pink), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 10rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.back-icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区块 */
.form-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-sizing: content-box;
}

.input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* 来源选择按钮 */
.source-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.source-btn:active {
  background: rgba(255, 255, 255, 0.12);
}

.source-icon {
  font-size: 36rpx;
}

.source-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.source-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 卡牌输入 */
.card-input-wrap {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  box-sizing: border-box;
}

.card-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.add-btn {
  width: 100rpx;
  height: 76rpx;
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.3);
}

.add-btn:active {
  transform: scale(0.96);
}

/* 卡牌列表 */
.card-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  min-height: 100rpx;
  padding: 10rpx;
}

.card-tag {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  background: rgba(255, 107, 157, 0.12);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 107, 157, 0.25);
  transition: all 0.2s;
}

.card-tag:active {
  background: rgba(255, 107, 157, 0.2);
}

.card-text {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-tag .delete {
  color: var(--neon-pink);
  font-size: 30rpx;
  font-weight: 600;
  padding: 4rpx;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: linear-gradient(180deg, transparent 0%, #16213e 30%);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.save-btn {
  height: 92rpx;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.save-btn.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
}

.save-btn.active {
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}

.save-btn.active:active {
  transform: scale(0.98);
}

/* 来源选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.source-picker {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 60rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  z-index: 101;
  transform: translateY(120%);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

.source-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.picker-close {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 8rpx;
}

.picker-content {
  padding: 16rpx 24rpx;
  max-height: 60vh;
  box-sizing: border-box;
}

.picker-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.picker-option:active {
  background: rgba(255, 255, 255, 0.08);
}

.option-icon {
  font-size: 40rpx;
}

.option-info {
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.option-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}