/* 全局变量 */
page {
  --primary: #ff6b6b;
  --primary-light: #ff8e8e;
  --secondary: #ffd93d;
  --bg-gradient: linear-gradient(180deg, #fff5f5 0%, #f8fafc 100%);
  --input-bg: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-gradient);
}

/* 顶部返回栏 */
.header-bar {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #64748b;
  transition: all 0.2s;
}

.back-btn:active {
  background: #e2e8f0;
  transform: scale(0.95);
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
  margin-right: 72rpx;
}

/* 表单区域 */
.form-section {
  flex: 1;
  padding: 48rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 44rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
  text-transform: uppercase;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.form-label-icon {
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 108rpx;
  padding: 0 36rpx;
  border-radius: 28rpx;
  background: var(--input-bg);
  border: 3rpx solid #f1f5f9;
  font-size: 30rpx;
  color: #1e293b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--primary);
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.15);
}

.form-input::placeholder {
  color: #cbd5e1;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 32rpx 36rpx;
  border-radius: 28rpx;
  background: var(--input-bg);
  border: 3rpx solid #f1f5f9;
  font-size: 30rpx;
  color: #1e293b;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s ease;
}

.form-textarea:focus {
  border-color: var(--primary);
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.15);
}

.form-textarea::placeholder {
  color: #cbd5e1;
}

/* 图标选择器 */
.icon-picker {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  background: var(--input-bg);
  padding: 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 3rpx solid #f1f5f9;
}

.icon-option {
  aspect-ratio: 1;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
}

.icon-option:hover {
  transform: scale(1.08);
}

.icon-option.selected {
  border-color: var(--primary);
  background: rgba(255, 107, 107, 0.08);
  transform: scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.2);
}

.icon-option.selected::after {
  content: '✓';
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  font-size: 18rpx;
  color: var(--primary);
  font-weight: bold;
}

.icon-emoji {
  font-size: 48rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

/* 底部栏 */
.bottom-bar {
  padding: 40rpx 48rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 2rpx solid #f1f5f9;
}

.create-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 28rpx;
  font-weight: 700;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  overflow: hidden;
}

.create-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
  pointer-events: none;
}

.create-btn.disabled {
  background: #e2e8f0;
  color: #94a3b8;
}

.create-btn.active {
  background: linear-gradient(145deg, #ff6b6b, #ff8e8e);
  color: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(255, 107, 107, 0.3);
}

.create-btn.active:active {
  transform: scale(0.97);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.25);
}

.create-btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}
