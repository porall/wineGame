/* 新建卡组页面样式 */
page {
  --primary: #ff6b9d;
  --primary-light: #ff8fb3;
  --text: #ffffff;
  --text-secondary: rgba(255, 255, 255, 0.7);
  --text-tertiary: rgba(255, 255, 255, 0.5);
  --bg: #1a1a2e;
  --card-bg: rgba(255, 255, 255, 0.08);
  --border: rgba(255, 255, 255, 0.15);
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 140rpx;
}

/* 标题 */
.header {
  padding: 20rpx 0 40rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 表单区块 */
.form-section {
  margin-bottom: 36rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text);
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.input::placeholder {
  color: var(--text-tertiary);
}

/* 来源选择按钮 */
.source-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
}

.source-icon {
  font-size: 36rpx;
}

.source-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 卡牌输入 */
.card-input-wrap {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.card-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--card-bg);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text);
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.card-input::placeholder {
  color: var(--text-tertiary);
}

.add-btn {
  width: 100rpx;
  height: 72rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 500;
}

.add-btn:active {
  background: var(--primary-light);
}

/* 卡牌列表 */
.card-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  min-height: 100rpx;
}

.card-tag {
  padding: 12rpx 18rpx;
  background: rgba(255, 107, 157, 0.15);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(255, 107, 157, 0.3);
}

.card-tag .delete {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: linear-gradient(180deg, transparent 0%, #16213e 30%);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.save-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.save-btn.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: var(--text-tertiary);
}

.save-btn.active {
  background: linear-gradient(135deg, var(--primary), #a55eea);
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
}

.save-btn.active:active {
  transform: scale(0.98);
}

/* 来源选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask.show {
  opacity: 1;
  visibility: visible;
}

.source-picker {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 60rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  border: 1rpx solid var(--border);
  z-index: 101;
  transform: translateY(120%);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

.source-picker.show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.picker-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.picker-content {
  padding: 16rpx 24rpx;
}

.picker-option {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
}

.picker-option:active {
  background: var(--card-bg);
}

.option-icon {
  font-size: 40rpx;
}

.option-info {
  display: flex;
  flex-direction: column;
}

.option-name {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.option-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}