/* 全局变量 */
page {
  --primary: #ff6b6b;
  --primary-light: #ff8e8e;
  --primary-dark: #e55a5a;
  --accent: #ffd93d;
  --bg-gradient: linear-gradient(135deg, #fff5f5 0%, #fff 50%, #fff9e6 100%);
  --card-shadow: 0 20rpx 60rpx -15rpx rgba(255, 107, 107, 0.25);
  --glass-bg: rgba(255, 255, 255, 0.85);
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: var(--bg-gradient);
  position: relative;
  overflow: hidden;
}

/* 动态背景 */
.bg-shapes {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.shape {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.6;
}

.shape-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  top: -100rpx;
  right: -100rpx;
  animation: morph 15s ease-in-out infinite;
}

.shape-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #ffd93d 0%, #ffed4a 100%);
  bottom: 10%;
  left: -80rpx;
  animation: morph 12s ease-in-out infinite reverse;
}

.shape-3 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  top: 40%;
  right: 5%;
  animation: morph 10s ease-in-out infinite;
}

@keyframes morph {
  0%, 100% { transform: scale(1) rotate(0deg); border-radius: 50%; }
  33% { transform: scale(1.1) rotate(120deg); border-radius: 40% 60% 60% 40%; }
  66% { transform: scale(0.9) rotate(240deg); border-radius: 60% 40% 40% 60%; }
}

/* 标题区域 */
.header {
  text-align: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
}

.title-wrapper {
  position: relative;
  display: inline-block;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 50%, #ffd93d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 4rpx;
  text-shadow: none;
}

.title-accent {
  position: absolute;
  top: -10rpx;
  right: -30rpx;
  font-size: 28rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

/* 分类选择 */
.category-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  max-width: 700rpx;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 1;
  padding: 0 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 36rpx;
  border-radius: 24rpx;
  background: var(--glass-bg);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  color: #64748b;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  min-width: 140rpx;
}

.category-item:hover {
  transform: translateY(-8rpx) scale(1.02);
  box-shadow: 0 16rpx 40rpx rgba(255, 107, 107, 0.15);
}

.category-item.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.35);
  transform: translateY(-4rpx) scale(1.05);
}

.category-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.category-text {
  font-weight: 600;
}

/* 抽卡池 */
.card-pool {
  width: 100%;
  padding: 0 40rpx;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.card-wrapper {
  width: 100%;
  height: 380rpx;
  perspective: 1500rpx;
}

.card {
  width: 100%;
  height: 100%;
  background: linear-gradient(145deg, #ffffff 0%, #fff9f9 100%);
  border-radius: 32rpx;
  box-shadow: 
    0 30rpx 60rpx -20rpx rgba(255, 107, 107, 0.2),
    0 10rpx 30rpx -10rpx rgba(0, 0, 0, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transform: scale(0.85) rotateX(15deg);
  transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(255, 107, 107, 0.3) 20%,
    rgba(255, 217, 61, 0.3) 80%,
    transparent 100%
  );
}

.card::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.4) 50%,
    transparent 70%
  );
  transform: translateX(-100%);
  transition: transform 0.6s;
}

.card.visible {
  opacity: 1;
  transform: scale(1) rotateX(0deg);
}

.card.visible::after {
  transform: translateX(100%);
}

.card.shake {
  animation: cardShake 0.5s ease-out;
}

@keyframes cardShake {
  0%, 100% { transform: translateX(0) rotateX(0deg); }
  20% { transform: translateX(-15rpx) rotateX(-2deg); }
  40% { transform: translateX(15rpx) rotateX(2deg); }
  60% { transform: translateX(-10rpx) rotateX(-1deg); }
  80% { transform: translateX(10rpx) rotateX(1deg); }
}

.card-pattern {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(255, 107, 107, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(255, 217, 61, 0.05) 0%, transparent 50%);
  pointer-events: none;
}

.card-content {
  font-size: 34rpx;
  text-align: center;
  padding: 40rpx 50rpx;
  color: #1e293b;
  line-height: 1.7;
  font-weight: 600;
  position: relative;
  z-index: 1;
}

/* 空状态 */
.card-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #cbd5e1;
}

.card-empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.card-empty-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* 抽卡按钮 */
.draw-button {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #ff6b6b, #ff8e8e);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 
    0 20rpx 40rpx rgba(255, 107, 107, 0.35),
    0 0 0 8rpx rgba(255, 107, 107, 0.1),
    inset 0 -4rpx 0 rgba(0, 0, 0, 0.1);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.draw-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.25) 0%, transparent 100%);
  border-radius: 50% 50% 0 0;
}

.draw-button::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 60%);
  transform: scale(0);
  transition: transform 0.5s;
}

.draw-button:active {
  transform: scale(0.92);
  box-shadow: 
    0 10rpx 24rpx rgba(255, 107, 107, 0.3),
    0 0 0 4rpx rgba(255, 107, 107, 0.1);
}

.draw-button:active::after {
  transform: scale(1);
}

.button-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.button-text {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
  letter-spacing: 4rpx;
}

.button-hint {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 底部信息 */
.footer {
  margin-top: auto;
  margin-bottom: 40rpx;
  padding: 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #94a3b8;
  text-align: center;
  font-weight: 500;
}

/* 提示动画 */
.tip-bubble {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  z-index: 100;
  animation: fadeInOut 2s ease forwards;
}

@keyframes fadeInOut {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
  20% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  80% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
}
