/* 聚会狂欢主题 - 炫酷动画版本 */
page {
  --primary: #ff4757;
  --secondary: #ffa502;
  --accent: #2ed573;
  --dark: #2f3542;
  --light: #ffffff;
  --neon-pink: #ff6b9d;
  --neon-blue: #00d2ff;
  --neon-purple: #a55eea;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* Canvas 背景 */
.party-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}

/* 标题区域 */
.header {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.title-wrapper {
  position: relative;
}

.title {
  font-size: 56rpx;
  font-weight: 900;
  background: linear-gradient(90deg, var(--neon-pink), var(--secondary), var(--neon-pink));
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 2s ease-in-out infinite;
  text-shadow: 0 0 30rpx rgba(255, 107, 157, 0.5);
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% center; }
  50% { background-position: 200% center; }
}

.glow-text {
  filter: drop-shadow(0 0 20rpx rgba(255, 165, 2, 0.8));
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}

.pulse {
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.7; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.05); }
}

/* 分类选择 - 霓虹风格 */
.category-container {
  position: relative;
  z-index: 10;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  width: 100%;
  max-width: 700rpx;
  padding: 20rpx 0;
}

.category-item.neon {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

.category-item.neon::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.category-item.neon:active::before {
  left: 100%;
}

.category-item.neon.active {
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  border-color: var(--neon-pink);
  transform: scale(1.08) translateY(-8rpx);
  box-shadow: 0 20rpx 40rpx rgba(255, 107, 157, 0.4),
              0 0 30rpx rgba(255, 107, 157, 0.6),
              inset 0 0 20rpx rgba(255, 255, 255, 0.2);
}

.category-item.neon:active {
  transform: scale(0.95);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.3));
}

.category-text {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
}

/* 3D卡片容器 */
.card-pool {
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  min-height: 400rpx;
  perspective: 1500rpx;
}

.card-3d-container {
  width: 520rpx;
  height: 320rpx;
  perspective: 1500rpx;
}

.card-3d {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.card-3d.show {
  transform: rotateY(180deg);
}

.card-3d.shake {
  animation: cardShake 0.5s ease-in-out;
}

@keyframes cardShake {
  0%, 100% { transform: rotateY(180deg) translateX(0); }
  20% { transform: rotateY(180deg) translateX(-20rpx) rotate(-5deg); }
  40% { transform: rotateY(180deg) translateX(20rpx) rotate(5deg); }
  60% { transform: rotateY(180deg) translateX(-10rpx) rotate(-3deg); }
  80% { transform: rotateY(180deg) translateX(10rpx) rotate(3deg); }
}

.card-inner {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.card-front {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 20rpx 60rpx rgba(102, 126, 234, 0.5),
              inset 0 0 60rpx rgba(255, 255, 255, 0.1);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.card-emoji {
  font-size: 120rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
}

.card-back {
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
  transform: rotateY(180deg);
  box-shadow: 0 20rpx 60rpx rgba(255, 154, 158, 0.5),
              inset 0 0 60rpx rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.card-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  text-align: center;
  padding: 40rpx;
  line-height: 1.6;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.5);
}

/* 抽卡按钮 - 彩虹渐变 */
.draw-button-wrapper {
  position: relative;
  z-index: 10;
  margin: 30rpx 0;
}

.rainbow-button {
  position: relative;
  width: 280rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(90deg, 
    #ff4757, 
    #ffa502, 
    #2ed573, 
    #1e90ff, 
    #a55eea, 
    #ff4757
  );
  background-size: 400% 100%;
  animation: rainbowFlow 4s linear infinite;
  box-shadow: 0 10rpx 30rpx rgba(255, 71, 87, 0.4),
              0 0 40rpx rgba(255, 165, 2, 0.3);
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  transition: transform 0.3s, box-shadow 0.3s;
}

@keyframes rainbowFlow {
  0% { background-position: 0% 50%; }
  100% { background-position: 400% 50%; }
}

.rainbow-button:active {
  transform: scale(0.92);
  box-shadow: 0 5rpx 20rpx rgba(255, 71, 87, 0.5),
              0 0 30rpx rgba(255, 165, 2, 0.4);
}

.button-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 40%,
    rgba(255, 255, 255, 0.3) 50%,
    transparent 60%
  );
  animation: shine 3s ease-in-out infinite;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.button-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.button-emoji {
  font-size: 48rpx;
  margin-bottom: 4rpx;
}

.button-text {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 底部装饰 */
.footer {
  position: relative;
  z-index: 10;
  padding: 30rpx 0;
}

.footer-confetti {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 10rpx;
  background: linear-gradient(90deg, 
    var(--neon-pink), 
    var(--secondary), 
    var(--accent), 
    var(--neon-blue)
  );
  border-radius: 5rpx;
  animation: confettiPulse 2s ease-in-out infinite;
}

@keyframes confettiPulse {
  0%, 100% { 
    width: 200rpx; 
    opacity: 0.5;
  }
  50% { 
    width: 300rpx; 
    opacity: 1;
  }
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 6rpx;
}

/* 状态栏 */
.status-bar {
  position: relative;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  margin: 20rpx 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.status-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.status-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.status-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 卡组管理面板 */
.deck-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.deck-panel-mask.show {
  opacity: 1;
  visibility: visible;
}

.deck-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 80vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;
}

.deck-panel.show {
  transform: translateY(0);
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.panel-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 10rpx;
}

.panel-tabs {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.panel-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  position: relative;
}

.panel-tab.active {
  color: #fff;
  font-weight: 600;
}

.panel-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: var(--neon-pink);
  border-radius: 3rpx;
}

.panel-content {
  padding: 20rpx 32rpx 40rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.deck-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.deck-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.deck-info {
  display: flex;
  align-items: center;
}

.deck-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.deck-meta {
  display: flex;
  flex-direction: column;
}

.deck-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

.deck-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.deck-switch {
  transform: scale(0.8);
}

.deck-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.deck-edit, .deck-delete {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.deck-edit {
  color: var(--neon-blue);
  background: rgba(0, 210, 255, 0.1);
}

.deck-delete {
  color: #ff4757;
  background: rgba(255, 71, 87, 0.1);
}

.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 28rpx;
}

.add-deck-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.add-icon {
  font-size: 36rpx;
  font-weight: 700;
}

/* 卡片来源标签 */
.card-source {
  display: block;
  font-size: 22rpx;
  color: rgba(45, 52, 54, 0.6);
  margin-top: 16rpx;
  text-align: center;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .title {
    font-size: 48rpx;
  }
  
  .card-3d-container {
    width: 90%;
    height: 280rpx;
  }
  
  .rainbow-button {
    width: 240rpx;
    height: 100rpx;
  }
}
