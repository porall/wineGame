/* 极简精致风格 - 第二轮迭代 */
page {
  --primary: #ff6b6b;
  --text: #111111;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --bg: #ffffff;
  --card-bg: #ffffff;
  --border: #e0e0e0;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg);
}

/* 标题区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 48rpx;
  background: var(--bg);
}

.title {
  font-size: 40rpx;
  font-weight: 500;
  color: var(--text);
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 分类选择 */
.category-container {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 14rpx 22rpx;
  border-radius: 8rpx;
  background: transparent;
  border: 1rpx solid var(--border);
  transition: all 0.15s;
}

.category-item.active {
  background: var(--primary);
  border-color: var(--primary);
}

.category-item.active .category-text {
  color: #fff;
}

.category-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.category-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: 400;
}

/* 抽卡池 */
.card-pool {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 32rpx;
}

.card-wrapper {
  width: 100%;
  max-width: 520rpx;
  height: 280rpx;
}

.card {
  width: 100%;
  height: 100%;
  background: var(--bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transform: scale(0.92);
  transition: all 0.25s ease-out;
}

.card.visible {
  opacity: 1;
  transform: scale(1);
}

.card.shake {
  animation: cardShake 0.3s ease-out;
}

@keyframes cardShake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-8rpx); }
  40% { transform: translateX(8rpx); }
  60% { transform: translateX(-4rpx); }
}

.card-content {
  font-size: 28rpx;
  text-align: center;
  padding: 32rpx;
  color: var(--text);
  line-height: 1.5;
}

/* 抽卡按钮 */
.draw-button {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 48rpx;
  border-radius: 50%;
  background: var(--primary);
}

.draw-button:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.button-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.button-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 2rpx;
}

.button-hint {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2rpx;
}

/* 底部信息 */
.footer {
  display: flex;
  justify-content: center;
  padding: 16rpx;
  margin-bottom: 32rpx;
}

.footer-text {
  font-size: 18rpx;
  color: var(--text-tertiary);
}
