/* 编辑卡组页面样式 - 与首页统一风格 */
page {
  --primary: #ff4757;
  --secondary: #ffa502;
  --accent: #2ed573;
  --neon-pink: #ff6b9d;
  --neon-blue: #00d2ff;
  --neon-purple: #a55eea;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: transparent;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 50rpx 24rpx 24rpx;
  background: rgba(0, 0, 0, 0.2);
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.back-button {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.back-button:active {
  background: rgba(255, 255, 255, 0.2);
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-left: 16rpx;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-right {
  display: flex;
  align-items: center;
}

.add-card-button {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 24rpx;
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.3);
}

.add-card-button:active {
  transform: scale(0.96);
}

.add-card-icon {
  font-size: 22rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  overflow: hidden;
}

.cards-scrollview {
  height: 100%;
  padding: 24rpx;
  overflow-y: auto;
}

/* 卡牌网格 */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding-bottom: 24rpx;
}

.card-item {
  background: rgba(255, 255, 255, 0.08);
  min-height: 160rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.card-item:active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.98);
}

.card-content {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.4;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

/* 模态框遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal-overlay.visible {
  opacity: 1;
  visibility: visible;
}

/* 模态框 */
.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.modal.visible {
  transform: translateY(0);
}

.modal-handle {
  width: 60rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.modal-close-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
}

.modal-close-button:active {
  background: rgba(255, 255, 255, 0.2);
}

.modal-body {
  margin-bottom: 24rpx;
}

.input-container {
  position: relative;
}

.card-textarea {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  font-size: 28rpx;
  color: #fff;
  line-height: 1.4;
  box-sizing: border-box;
}

.card-textarea::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.card-textarea:focus {
  border-color: var(--neon-pink);
  background: rgba(255, 255, 255, 0.1);
}

.char-counter {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 模态框底部按钮 */
.modal-footer {
  display: flex;
  gap: 16rpx;
}

.cancel-button {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-button:active {
  background: rgba(255, 255, 255, 0.1);
}

.confirm-button {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.confirm-button.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.3);
}

.confirm-button.active {
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 157, 0.4);
}

.confirm-button.active:active {
  transform: scale(0.98);
}