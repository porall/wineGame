/* 极简精致风格 - 第二轮迭代 */
page {
  --primary: #ff6b6b;
  --text: #111111;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --bg: #ffffff;
  --card-bg: #ffffff;
  --border: #e0e0e0;
  --border-light: #f5f5f5;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg);
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border-light);
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.back-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-secondary);
  background: var(--border-light);
  border-radius: 50%;
}

.back-button:active {
  background: var(--border);
}

.page-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
  margin-left: 12rpx;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-right {
  display: flex;
  align-items: center;
}

.add-card-button {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  background: var(--primary);
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #fff;
}

.add-card-button:active {
  opacity: 0.85;
}

.add-card-icon {
  font-size: 20rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  overflow: hidden;
}

.cards-scrollview {
  height: 100%;
  padding: 16rpx;
  overflow-y: auto;
}

/* 卡牌网格 */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding-bottom: 24rpx;
}

.card-item {
  background: var(--card-bg);
  min-height: 160rpx;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: 1rpx solid var(--border-light);
}

.card-item:active {
  background: var(--border-light);
}

.card-content {
  font-size: 24rpx;
  color: var(--text);
  line-height: 1.4;
  word-break: break-all;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-hint {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 模态框遮罩 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.35);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.15s;
}

.modal-overlay.visible {
  opacity: 1;
  visibility: visible;
}

/* 模态框 */
.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-bg);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.2s ease-out;
}

.modal.visible {
  transform: translateY(0);
}

.modal-handle {
  width: 48rpx;
  height: 6rpx;
  background: var(--border);
  border-radius: 3rpx;
  margin: 0 auto 20rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
}

.modal-close-button {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border-light);
  border-radius: 50%;
  font-size: 32rpx;
  color: var(--text-secondary);
}

.modal-close-button:active {
  background: var(--border);
}

.modal-body {
  margin-bottom: 24rpx;
}

.input-container {
  position: relative;
}

.card-textarea {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background: var(--border-light);
  border-radius: 8rpx;
  border: 1rpx solid transparent;
  font-size: 26rpx;
  color: var(--text);
  text-align: center;
  line-height: 1.4;
}

.card-textarea:focus {
  border-color: var(--primary);
  background: var(--card-bg);
}

.char-counter {
  position: absolute;
  bottom: 12rpx;
  right: 20rpx;
  font-size: 18rpx;
  color: var(--text-tertiary);
}

/* 模态框底部按钮 */
.modal-footer {
  display: flex;
  gap: 12rpx;
}

.cancel-button {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--border);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-button:active {
  background: var(--border-light);
}

.confirm-button {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-button.disabled {
  background: var(--border-light);
  color: var(--text-tertiary);
}

.confirm-button.active {
  background: var(--primary);
  color: #fff;
}

.confirm-button.active:active {
  opacity: 0.85;
}
