/* 极简精致风格 - 第二轮迭代 */
page {
  --primary: #ff6b6b;
  --text: #111111;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --bg: #ffffff;
  --card-bg: #ffffff;
  --border: #e0e0e0;
  --border-light: #f5f5f5;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg);
}

/* 顶部 Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 80rpx 32rpx 28rpx;
  background: var(--card-bg);
  border-bottom: 1rpx solid var(--border-light);
}

.header-left {
  display: flex;
  flex-direction: column;
}

.greeting-label {
  font-size: 18rpx;
  color: var(--text-tertiary);
}

.greeting-text {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text);
  margin-top: 2rpx;
}

.avatar-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--border-light);
}

.avatar {
  width: 100%;
  height: 100%;
}

/* 标题区域 */
.section-title {
  padding: 28rpx 32rpx 20rpx;
  display: flex;
  align-items: center;
}

.section-title-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
}

/* 卡组网格 */
.deck-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 32rpx 160rpx;
}

.deck-item {
  background: var(--card-bg);
  padding: 24rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.deck-item:active {
  background: var(--border-light);
}

.deck-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.deck-icon {
  font-size: 32rpx;
}

.deck-name {
  font-weight: 400;
  font-size: 24rpx;
  color: var(--text);
  text-align: center;
}

.deck-count {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 空状态 */
.deck-empty {
  grid-column: span 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx;
  background: var(--card-bg);
  border-radius: 8rpx;
  border: 1rpx dashed var(--border);
}

.deck-empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.4;
}

.deck-empty-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.deck-empty-hint {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  bottom: 48rpx;
  right: 32rpx;
  width: 88rpx;
  height: 88rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-button:active {
  transform: scale(0.94);
  opacity: 0.85;
}

.fab-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}
