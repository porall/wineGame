/* 卡组页面样式 - 与首页统一风格 */
page {
  --primary: #ff4757;
  --secondary: #ffa502;
  --accent: #2ed573;
  --dark: #2f3542;
  --light: #ffffff;
  --neon-pink: #ff6b9d;
  --neon-blue: #00d2ff;
  --neon-purple: #a55eea;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 标题区域 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 60rpx 20rpx 40rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.greeting-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 2rpx;
}

.greeting-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 8rpx;
}

.avatar-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

/* 区块标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 1rpx;
}

/* 卡组网格 */
.deck-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.deck-item {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.deck-item:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.12);
}

.deck-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
}

.deck-icon {
  font-size: 40rpx;
}

.deck-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
  margin-bottom: 8rpx;
}

.deck-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 空状态 */
.deck-empty {
  grid-column: span 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.15);
}

.deck-empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.deck-empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.deck-empty-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  bottom: 48rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--neon-pink), var(--neon-purple));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(255, 107, 157, 0.4);
  transition: all 0.3s;
}

.fab-button:active {
  transform: scale(0.92);
  box-shadow: 0 5rpx 20rpx rgba(255, 107, 157, 0.5);
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
}