/* 极简精致风格 - 第二轮迭代 */
page {
  --primary: #ff6b6b;
  --text: #111111;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --bg: #ffffff;
  --card-bg: #ffffff;
  --border: #e0e0e0;
  --border-light: #f5f5f5;
}

.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background: var(--card-bg);
}

.search-input {
  height: 64rpx;
  padding: 0 24rpx;
  background: var(--border-light);
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 标签 */
.tags-scroll {
  background: var(--card-bg);
  padding: 0 16rpx 16rpx;
  white-space: nowrap;
  border-bottom: 1rpx solid var(--border-light);
}

.tags-list {
  display: inline-flex;
  gap: 10rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background: var(--border-light);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
}

.tag-item.active {
  background: var(--primary);
  color: #fff;
}

/* 卡组列表 */
.deck-list {
  padding: 16rpx;
}

.deck-card {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  background: var(--card-bg);
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--border-light);
}

.deck-card:active {
  background: var(--border-light);
}

.deck-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.deck-info {
  flex: 1;
  min-width: 0;
}

.deck-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
}

.deck-desc {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.deck-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
  font-size: 18rpx;
  color: var(--text-tertiary);
}

/* 空状态 */
.empty, .loading, .no-more {
  text-align: center;
  padding: 48rpx;
  color: var(--text-tertiary);
  font-size: 22rpx;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  bottom: 48rpx;
  right: 32rpx;
  width: 88rpx;
  height: 88rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
}

.fab-button:active {
  transform: scale(0.94);
  opacity: 0.85;
}
