/* 全局变量 */
page {
  --primary: #ff6b6b;
  --bg: #f8fafc;
}

.container {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  height: 72rpx;
  padding: 0 30rpx;
  background: #f1f5f9;
  border-radius: 36rpx;
  font-size: 28rpx;
}

/* 标签 */
.tags-scroll {
  background: #fff;
  padding: 0 20rpx 20rpx;
  white-space: nowrap;
}

.tags-list {
  display: inline-flex;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  background: #f1f5f9;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #64748b;
}

.tag-item.active {
  background: var(--primary);
  color: #fff;
}

/* 卡组列表 */
.deck-list {
  padding: 20rpx;
}

.deck-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.deck-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.deck-info {
  flex: 1;
  min-width: 0;
}

.deck-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.deck-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.deck-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #cbd5e1;
}

/* 空状态 */
.empty, .loading, .no-more {
  text-align: center;
  padding: 60rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ff6b6b, #ff8e8e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}
