/* 极简精致风格 - 第二轮迭代 */
page {
  --primary: #ff6b6b;
  --text: #111111;
  --text-secondary: #555555;
  --text-tertiary: #888888;
  --bg: #ffffff;
  --card-bg: #ffffff;
  --border: #e0e0e0;
  --border-light: #f5f5f5;
}

.container {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.input, .textarea {
  width: 100%;
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  border: 1rpx solid var(--border);
}

.input:focus, .textarea:focus {
  border-color: var(--primary);
}

.textarea {
  height: 120rpx;
}

/* 图标 */
.icon-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.icon-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 1rpx solid transparent;
}

.icon-item.active {
  border-color: var(--primary);
}

/* 标签 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-item {
  padding: 8rpx 18rpx;
  background: var(--bg);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

.tag-item.active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

/* 卡牌输入 */
.card-input-wrap {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.card-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  background: var(--bg);
  border-radius: 8rpx;
  font-size: 26rpx;
  border: 1rpx solid var(--border);
}

.add-btn {
  width: 88rpx;
  height: 64rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.add-btn:active {
  opacity: 0.85;
}

.card-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-tag {
  padding: 8rpx 14rpx;
  background: var(--border-light);
  border-radius: 6rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.card-tag .delete {
  color: var(--text-tertiary);
  font-size: 24rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-light);
}

.publish-btn {
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.publish-btn.disabled {
  background: var(--border-light);
  color: var(--text-tertiary);
}

.publish-btn.active {
  background: var(--primary);
  color: #fff;
}
