<view class="container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 内容 -->
  <block wx:elif="{{deck}}">
    <!-- 头部 -->
    <view class="header">
      <view class="back-button" bindtap="goBack">‹</view>
    </view>

    <!-- 卡组信息 -->
    <view class="deck-info">
      <view class="deck-icon-wrapper" style="background-color: {{deck.iconBg}}">
        <text class="deck-icon">{{deck.icon}}</text>
      </view>
      <text class="deck-name">{{deck.name}}</text>
      <text class="deck-desc">{{deck.description}}</text>
      <view class="deck-tags" wx:if="{{deck.tags}}">
        <text class="tag" wx:for="{{deck.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <view class="action-btn {{isLiked ? 'active' : ''}}" bindtap="toggleLike">
        <text>{{isLiked ? '❤️ 已收藏' : '🤍 收藏'}}</text>
      </view>
      <view class="action-btn primary" bindtap="useDeck" wx:if="{{!isUsed}}">
        <text>🎴 导入卡组</text>
      </view>
      <view class="action-btn disabled" wx:else>
        <text>✓ 已导入</text>
      </view>
    </view>

    <!-- 卡牌列表 -->
    <view class="cards-section">
      <text class="section-title">卡牌列表 ({{deck.cards.length}})</text>
      <view class="cards-grid">
        <view class="card-item" wx:for="{{deck.cards}}" wx:key="*this">
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text>卡组不存在</text>
  </view>
</view>
