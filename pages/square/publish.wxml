<view class="container">
  <!-- 名称 -->
  <view class="form-item">
    <view class="label">卡组名称 *</view>
    <input 
      class="input" 
      placeholder="请输入名称" 
      maxlength="20"
      value="{{name}}"
      bindinput="onNameInput"
    />
  </view>

  <!-- 描述 -->
  <view class="form-item">
    <view class="label">描述</view>
    <textarea 
      class="textarea" 
      placeholder="简单描述一下这个卡组"
      maxlength="100"
      value="{{description}}"
      bindinput="onDescInput"
    />
  </view>

  <!-- 图标 -->
  <view class="form-item">
    <view class="label">选择图标</view>
    <view class="icon-list">
      <view 
        wx:for="{{icons}}" 
        wx:key="icon"
        class="icon-item {{selectedIcon === item.icon ? 'active' : ''}}"
        style="background-color: {{item.bg}}"
        bindtap="selectIcon"
        data-icon="{{item.icon}}"
      >{{item.icon}}</view>
    </view>
  </view>

  <!-- 标签 -->
  <view class="form-item">
    <view class="label">标签（最多3个）</view>
    <view class="tag-list">
      <view 
        wx:for="{{tags}}" 
        wx:key="*this"
        class="tag-item {{selectedTags.includes(item) ? 'active' : ''}}"
        bindtap="toggleTag"
        data-tag="{{item}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 卡牌 -->
  <view class="form-item">
    <view class="label">卡牌内容 * ({{cards.length}}/100)</view>
    <view class="card-input-wrap">
      <input 
        class="card-input" 
        placeholder="输入卡牌内容，按回车添加"
        maxlength="50"
        value="{{cardInput}}"
        bindinput="onCardInput"
        bindconfirm="addCard"
      />
      <view class="add-btn" bindtap="addCard">添加</view>
    </view>
    <view class="card-list">
      <view 
        wx:for="{{cards}}" 
        wx:key="*this"
        class="card-tag"
      >
        {{item}}
        <text class="delete" bindtap="deleteCard" data-index="{{index}}">×</text>
      </view>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="bottom-bar">
    <view 
      class="publish-btn {{canPublish ? 'active' : 'disabled'}}"
      bindtap="publish"
    >发布到广场</view>
  </view>
</view>
